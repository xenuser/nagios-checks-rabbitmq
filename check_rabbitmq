_debug_enabled = False


def debug(msg: str) -> None:
    """Print a debug message to stderr if debug mode is enabled."""
    if _debug_enabled:
        ts = time.strftime("%H:%M:%S", time.localtime())
        print(f"[DEBUG {ts}] {msg}", file=sys.stderr)


def sanitize(text: str, password: str, username: str = "") -> str:
    """
    Remove credentials from any string before it is logged or displayed.
    Replaces the password (and base64-encoded forms of it) with '***'.
    """
    if not text:
        return text
    sanitized = text
    if password:
        sanitized = sanitized.replace(password, "***")
        try:
            b64_creds = base64.b64encode(f"{username}:{password}".encode()).decode()
            sanitized = sanitized.replace(b64_creds, "***b64***")
        except Exception:
            pass
        try:
            b64_pass = base64.b64encode(password.encode()).decode()
            sanitized = sanitized.replace(b64_pass, "***b64***")
        except Exception:
            pass
    return sanitized


_g_password = ""
_g_username = ""


def safe(text: str) -> str:
    """Shorthand: sanitize text using the globally-registered credentials."""
    return sanitize(text, _g_password, _g_username)


# =============================================================================
# HTTP Status Code Descriptions
# =============================================================================

HTTP_STATUS_DESCRIPTIONS = {
    400: "Bad Request - the server could not understand the request",
    401: "Unauthorized - authentication failed (check username and permissions)",
    403: "Forbidden - user does not have sufficient permissions",
    404: "Not Found - the requested resource does not exist",
    405: "Method Not Allowed",
    406: "Not Acceptable - invalid content type requested",
    408: "Request Timeout - the server did not respond in time",
    413: "Payload Too Large",
    429: "Too Many Requests - rate limit exceeded",
    500: "Internal Server Error - RabbitMQ encountered an unexpected condition",
    502: "Bad Gateway - upstream server error",
    503: "Service Unavailable - RabbitMQ is starting up, shutting down, or overloaded",
    504: "Gateway Timeout",
}


def describe_http_error(status: int, path: str, body: Any = None) -> str:
    """Build a human-readable error message for an HTTP error response."""
    desc = HTTP_STATUS_DESCRIPTIONS.get(status, f"HTTP {status}")
    msg = f"Management API {path} returned {status} ({desc})"
    if isinstance(body, dict):
        reason = body.get("reason") or body.get("error") or body.get("message")
        if reason:
            msg += f": {safe(str(reason))}"
    elif isinstance(body, str) and body.strip():
        short = body.strip()[:200]
        if "<html" not in short.lower():
            msg += f": {safe(short)}"
    return msg


# =============================================================================
# AMQP 0-9-1 Constants
# =============================================================================
AMQP_PROTOCOL_HEADER = b"AMQP\x00\x00\x09\x01"

FRAME_METHOD = 1
FRAME_HEADER = 2
FRAME_BODY = 3
FRAME_HEARTBEAT = 8
FRAME_END = 0xCE

FRAME_TYPE_NAMES = {
    FRAME_METHOD: "METHOD",
    FRAME_HEADER: "HEADER",
    FRAME_BODY: "BODY",
    FRAME_HEARTBEAT: "HEARTBEAT",
}

CLASS_CONNECTION = 10
CLASS_CHANNEL = 20
CLASS_EXCHANGE = 40
CLASS_QUEUE = 50
CLASS_BASIC = 60

METHOD_CONNECTION_START = (10, 10)
METHOD_CONNECTION_START_OK = (10, 11)
METHOD_CONNECTION_TUNE = (10, 30)
METHOD_CONNECTION_TUNE_OK = (10, 31)
METHOD_CONNECTION_OPEN = (10, 40)
METHOD_CONNECTION_OPEN_OK = (10, 41)
METHOD_CONNECTION_CLOSE = (10, 50)
METHOD_CONNECTION_CLOSE_OK = (10, 51)

METHOD_CHANNEL_OPEN = (20, 10)
METHOD_CHANNEL_OPEN_OK = (20, 11)
METHOD_CHANNEL_CLOSE = (20, 40)
METHOD_CHANNEL_CLOSE_OK = (20, 41)

METHOD_QUEUE_DECLARE = (50, 10)
METHOD_QUEUE_DECLARE_OK = (50, 11)
METHOD_QUEUE_DELETE = (50, 40)
METHOD_QUEUE_DELETE_OK = (50, 41)

METHOD_BASIC_PUBLISH = (60, 40)
METHOD_BASIC_GET = (60, 70)
METHOD_BASIC_GET_OK = (60, 71)
METHOD_BASIC_GET_EMPTY = (60, 72)
METHOD_BASIC_ACK = (60, 80)

METHOD_NAMES = {
    (10, 10): "Connection.Start",
    (10, 11): "Connection.Start-OK",
    (10, 30): "Connection.Tune",
    (10, 31): "Connection.Tune-OK",
    (10, 40): "Connection.Open",
    (10, 41): "Connection.Open-OK",
    (10, 50): "Connection.Close",
    (10, 51): "Connection.Close-OK",
    (20, 10): "Channel.Open",
    (20, 11): "Channel.Open-OK",
    (20, 40): "Channel.Close",
    (20, 41): "Channel.Close-OK",
    (50, 10): "Queue.Declare",
    (50, 11): "Queue.Declare-OK",
    (50, 40): "Queue.Delete",
    (50, 41): "Queue.Delete-OK",
    (60, 40): "Basic.Publish",
    (60, 70): "Basic.Get",
    (60, 71): "Basic.Get-OK",
    (60, 72): "Basic.Get-Empty",
    (60, 80): "Basic.Ack",
}


def method_name(class_id: int, method_id: int) -> str:
    return METHOD_NAMES.get((class_id, method_id), f"({class_id},{method_id})")


class AMQPError(Exception):
    """AMQP protocol error."""
    pass


class AMQPClient:
    """
    Minimal AMQP 0-9-1 client using raw sockets.
    Supports: connect, declare quorum queue, publish, get, ack, delete, close.
    """

    def __init__(
        self,
        host: str,
        port: int,
        vhost: str,
        username: str,
        password: str,
        use_ssl: bool = False,
        ssl_ca_cert: Optional[str] = None,
        ssl_cert: Optional[str] = None,
        ssl_key: Optional[str] = None,
        ssl_no_verify: bool = False,
        timeout: int = 10,
    ):
        self.host = host
        self.port = port
        self.vhost = vhost
        self.username = username
        self.password = password
        self.use_ssl = use_ssl
        self.ssl_ca_cert = ssl_ca_cert
        self.ssl_cert = ssl_cert
        self.ssl_key = ssl_key
        self.ssl_no_verify = ssl_no_verify
        self.timeout = timeout
        self.sock: Optional[socket.socket] = None
        self.channel_id = 1
        self.frame_max = 131072
        self._connected = False

    def connect(self) -> None:
        proto = "amqps" if self.use_ssl else "amqp"
        debug(f"AMQP connecting to {proto}://{self.host}:{self.port}/{self.vhost} as user '{self.username}'")

        raw = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        raw.settimeout(self.timeout)
        debug(f"Socket created, timeout={self.timeout}s")

        if self.use_ssl:
            debug("TLS: setting up SSL context")
            ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_CLIENT)
            if self.ssl_no_verify:
                ctx.check_hostname = False
                ctx.verify_mode = ssl.CERT_NONE
                debug("TLS: certificate verification DISABLED (--ssl-no-verify)")
            else:
                ctx.verify_mode = ssl.CERT_REQUIRED
                ctx.check_hostname = True
                debug("TLS: certificate verification enabled")
            if self.ssl_ca_cert:
                ctx.load_verify_locations(self.ssl_ca_cert)
                debug(f"TLS: loaded CA cert from {self.ssl_ca_cert}")
            else:
                ctx.load_default_certs()
                debug("TLS: using system default CA certificates")
            if self.ssl_cert and self.ssl_key:
                ctx.load_cert_chain(self.ssl_cert, self.ssl_key)
                debug(f"TLS: loaded client cert={self.ssl_cert}, key={self.ssl_key}")
            self.sock = ctx.wrap_socket(raw, server_hostname=self.host)
            debug("TLS: handshake complete")
        else:
            self.sock = raw

        self.sock.connect((self.host, self.port))
        debug(f"TCP connected to {self.host}:{self.port}")

        self.sock.sendall(AMQP_PROTOCOL_HEADER)
        debug("Sent AMQP 0-9-1 protocol header")

        class_id, mid, payload = self._read_method(0)
        if (class_id, mid) != METHOD_CONNECTION_START:
            raise AMQPError(f"Expected Connection.Start, got {method_name(class_id, mid)}")
        debug("Received Connection.Start from server")

        self._send_connection_start_ok()
        debug("Sent Connection.Start-OK (PLAIN auth)")

        class_id, mid, payload = self._read_method(0)
        if (class_id, mid) != METHOD_CONNECTION_TUNE:
            raise AMQPError(f"Expected Connection.Tune, got {method_name(class_id, mid)}")
        chan_max, frame_max, heartbeat = struct.unpack("!HIH", payload)
        self.frame_max = frame_max if frame_max > 0 else 131072
        debug(f"Received Connection.Tune: channel_max={chan_max}, frame_max={self.frame_max}, heartbeat={heartbeat}")

        tune_ok_payload = struct.pack("!HIH", chan_max, self.frame_max, 0)
        self._send_method(0, CLASS_CONNECTION, 31, tune_ok_payload)
        debug("Sent Connection.Tune-OK (heartbeat=0)")

        vhost_encoded = self._encode_short_string(self.vhost)
        open_payload = vhost_encoded + b"\x00\x00"
        self._send_method(0, CLASS_CONNECTION, 40, open_payload)
        debug(f"Sent Connection.Open for vhost '{self.vhost}'")

        class_id, mid, payload = self._read_method(0)
        if (class_id, mid) != METHOD_CONNECTION_OPEN_OK:
            raise AMQPError(f"Expected Connection.Open-OK, got {method_name(class_id, mid)}")
        debug("Received Connection.Open-OK - AMQP connection established")
        self._connected = True

    def open_channel(self) -> None:
        debug(f"Opening AMQP channel {self.channel_id}")
        payload = self._encode_short_string("")
        self._send_method(self.channel_id, CLASS_CHANNEL, 10, payload)
        class_id, mid, payload = self._read_method(self.channel_id)
        if (class_id, mid) != METHOD_CHANNEL_OPEN_OK:
            raise AMQPError(f"Expected Channel.Open-OK, got {method_name(class_id, mid)}")
        debug(f"Channel {self.channel_id} opened")

    def declare_quorum_queue(self, queue_name: str) -> Tuple[str, int, int]:
        """Declare a quorum queue. Returns (queue_name, message_count, consumer_count)."""
        debug(f"Declaring quorum queue '{queue_name}' (durable=true, x-queue-type=quorum)")
        payload = bytearray()
        payload += struct.pack("!H", 0)
        payload += self._encode_short_string(queue_name)
        bits = 0
        bits |= (1 << 1)  # durable
        payload += struct.pack("B", bits)
        args_table = self._encode_table({"x-queue-type": "quorum"})
        payload += args_table
        self._send_method(self.channel_id, CLASS_QUEUE, 10, bytes(payload))
        class_id, mid, resp = self._read_method(self.channel_id)
        if (class_id, mid) != METHOD_QUEUE_DECLARE_OK:
            raise AMQPError(f"Expected Queue.Declare-OK, got {method_name(class_id, mid)}")
        name, offset = self._decode_short_string(resp, 0)
        msg_count, consumer_count = struct.unpack_from("!II", resp, offset)
        debug(f"Queue.Declare-OK: name='{name}', messages={msg_count}, consumers={consumer_count}")
        return name, msg_count, consumer_count

    def declare_queue_passive(self, queue_name: str) -> Tuple[str, int, int]:
        """Passively declare a queue (check existence). Raises AMQPError if not found."""
        debug(f"Passively declaring queue '{queue_name}' (passive=true)")
        payload = bytearray()
        payload += struct.pack("!H", 0)
        payload += self._encode_short_string(queue_name)
        bits = (1 << 0)  # passive
        payload += struct.pack("B", bits)
        payload += self._encode_table({})
        self._send_method(self.channel_id, CLASS_QUEUE, 10, bytes(payload))
        class_id, mid, resp = self._read_method(self.channel_id)
        if (class_id, mid) != METHOD_QUEUE_DECLARE_OK:
            raise AMQPError(f"Expected Queue.Declare-OK, got {method_name(class_id, mid)}")
        name, offset = self._decode_short_string(resp, 0)
        msg_count, consumer_count = struct.unpack_from("!II", resp, offset)
        debug(f"Queue.Declare-OK (passive): name='{name}', messages={msg_count}, consumers={consumer_count}")
        return name, msg_count, consumer_count

    def delete_queue(self, queue_name: str) -> int:
        """Delete a queue. Returns message count."""
        debug(f"Deleting queue '{queue_name}'")
        payload = bytearray()
        payload += struct.pack("!H", 0)
        payload += self._encode_short_string(queue_name)
        payload += struct.pack("B", 0)
        self._send_method(self.channel_id, CLASS_QUEUE, 40, bytes(payload))
        class_id, mid, resp = self._read_method(self.channel_id)
        if (class_id, mid) != METHOD_QUEUE_DELETE_OK:
            raise AMQPError(f"Expected Queue.Delete-OK, got {method_name(class_id, mid)}")
        msg_count = struct.unpack_from("!I", resp, 0)[0]
        debug(f"Queue.Delete-OK: '{queue_name}' deleted, {msg_count} messages purged")
        return msg_count

    def basic_publish(self, exchange: str, routing_key: str, body: bytes,
                      properties: Optional[Dict] = None) -> None:
        """Publish a message."""
        payload = bytearray()
        payload += struct.pack("!H", 0)
        payload += self._encode_short_string(exchange)
        payload += self._encode_short_string(routing_key)
        payload += struct.pack("B", 0)
        self._send_method(self.channel_id, CLASS_BASIC, 40, bytes(payload))

        body_size = len(body)
        prop_flags = 0
        prop_payload = bytearray()
        prop_flags |= (1 << 12)  # delivery-mode present
        prop_payload += struct.pack("B", 2)  # persistent

        header = struct.pack("!HHQ", 60, 0, body_size)
        header += struct.pack("!H", prop_flags)
        header += bytes(prop_payload)
        self._send_frame(FRAME_HEADER, self.channel_id, header)

        max_body = self.frame_max - 8
        offset = 0
        while offset < len(body):
            chunk = body[offset:offset + max_body]
            self._send_frame(FRAME_BODY, self.channel_id, chunk)
            offset += len(chunk)

    def basic_get(self, queue_name: str) -> Optional[Tuple[int, bytes]]:
        """Get a single message. Returns (delivery_tag, body) or None."""
        payload = bytearray()
        payload += struct.pack("!H", 0)
        payload += self._encode_short_string(queue_name)
        payload += struct.pack("B", 0)  # no-ack = false
        self._send_method(self.channel_id, CLASS_BASIC, 70, bytes(payload))

        class_id, mid, resp = self._read_method(self.channel_id)

        if (class_id, mid) == METHOD_BASIC_GET_EMPTY:
            return None
        if (class_id, mid) != METHOD_BASIC_GET_OK:
            raise AMQPError(f"Expected Basic.Get-OK or Get-Empty, got {method_name(class_id, mid)}")

        delivery_tag = struct.unpack_from("!Q", resp, 0)[0]

        frame_type, channel, header_payload = self._read_frame()
        if frame_type != FRAME_HEADER:
            raise AMQPError(f"Expected content header, got frame type {frame_type}")
        body_size = struct.unpack_from("!Q", header_payload, 4)[0]

        body = bytearray()
        while len(body) < body_size:
            frame_type, channel, body_chunk = self._read_frame()
            if frame_type != FRAME_BODY:
                raise AMQPError(f"Expected body frame, got frame type {frame_type}")
            body += body_chunk

        return delivery_tag, bytes(body)

    def basic_ack(self, delivery_tag: int) -> None:
        payload = struct.pack("!QB", delivery_tag, 0)
        self._send_method(self.channel_id, CLASS_BASIC, 80, payload)

    def close_channel(self) -> None:
        try:
            debug(f"Closing AMQP channel {self.channel_id}")
            payload = struct.pack("!H", 200) + self._encode_short_string("Normal shutdown") + struct.pack("!HH", 0, 0)
            self._send_method(self.channel_id, CLASS_CHANNEL, 40, payload)
            self._read_method(self.channel_id)
            debug(f"Channel {self.channel_id} closed")
        except Exception as e:
            debug(f"Channel close error (non-fatal): {safe(str(e))}")

    def close_connection(self) -> None:
        try:
            debug("Closing AMQP connection")
            payload = struct.pack("!H", 200) + self._encode_short_string("Normal shutdown") + struct.pack("!HH", 0, 0)
            self._send_method(0, CLASS_CONNECTION, 50, payload)
            try:
                self._read_method(0)
                debug("Connection.Close-OK received")
            except Exception:
                pass
        except Exception as e:
            debug(f"Connection close error (non-fatal): {safe(str(e))}")
        finally:
            if self.sock:
                try:
                    self.sock.close()
                except Exception:
                    pass
                self.sock = None
            self._connected = False
            debug("AMQP connection closed")

    def close(self) -> None:
        if self._connected:
            self.close_channel()
            self.close_connection()
        elif self.sock:
            try:
                self.sock.close()
            except Exception:
                pass
            self.sock = None

    # ---- encoding helpers ----

    @staticmethod
    def _encode_short_string(s: str) -> bytes:
        encoded = s.encode("utf-8")
        if len(encoded) > 255:
            raise AMQPError(f"Short string too long: {len(encoded)} bytes")
        return struct.pack("B", len(encoded)) + encoded

    @staticmethod
    def _decode_short_string(data: bytes, offset: int) -> Tuple[str, int]:
        length = data[offset]
        offset += 1
        s = data[offset:offset + length].decode("utf-8")
        return s, offset + length

    @staticmethod
    def _encode_long_string(s: str) -> bytes:
        encoded = s.encode("utf-8")
        return struct.pack("!I", len(encoded)) + encoded

    @staticmethod
    def _encode_table(d: Dict[str, Any]) -> bytes:
        buf = bytearray()
        for key, value in d.items():
            key_bytes = key.encode("utf-8")
            buf += struct.pack("B", len(key_bytes))
            buf += key_bytes
            if isinstance(value, str):
                buf += b"S"
                val_bytes = value.encode("utf-8")
                buf += struct.pack("!I", len(val_bytes))
                buf += val_bytes
            elif isinstance(value, int):
                buf += b"I"
                buf += struct.pack("!i", value)
            elif isinstance(value, bool):
                buf += b"t"
                buf += struct.pack("B", 1 if value else 0)
        return struct.pack("!I", len(buf)) + bytes(buf)

    # ---- frame I/O ----

    def _read_exact(self, n: int) -> bytes:
        data = bytearray()
        while len(data) < n:
            chunk = self.sock.recv(n - len(data))
            if not chunk:
                raise AMQPError("Connection closed by server")
            data += chunk
        return bytes(data)

    def _read_frame(self) -> Tuple[int, int, bytes]:
        header = self._read_exact(7)
        frame_type, channel, size = struct.unpack("!BHI", header)
        payload = self._read_exact(size) if size > 0 else b""
        end = self._read_exact(1)
        if end[0] != FRAME_END:
            raise AMQPError(f"Invalid frame end marker: 0x{end[0]:02x}")
        frame_name = FRAME_TYPE_NAMES.get(frame_type, f"UNKNOWN({frame_type})")
        if frame_type == FRAME_METHOD and size >= 4:
            cid, mid_val = struct.unpack_from("!HH", payload, 0)
            debug(f"  << Frame: {frame_name} ch={channel} {method_name(cid, mid_val)} ({size} bytes)")
        elif frame_type != FRAME_BODY:
            debug(f"  << Frame: {frame_name} ch={channel} ({size} bytes)")
        return frame_type, channel, payload

    def _read_method(self, expected_channel: int) -> Tuple[int, int, bytes]:
        while True:
            frame_type, channel, payload = self._read_frame()
            if frame_type == FRAME_HEARTBEAT:
                debug("Heartbeat received, sending heartbeat response")
                self._send_frame(FRAME_HEARTBEAT, 0, b"")
                continue
            if frame_type == FRAME_METHOD:
                if channel != expected_channel:
                    if channel == 0:
                        class_id, mid_val = struct.unpack_from("!HH", payload, 0)
                        if (class_id, mid_val) == METHOD_CONNECTION_CLOSE:
                            reply_code = struct.unpack_from("!H", payload, 4)[0]
                            reply_text, _ = self._decode_short_string(payload, 6)
                            debug(f"Server forced connection close: {reply_code} - {safe(reply_text)}")
                            raise AMQPError(f"Server closed connection: {reply_code} - {safe(reply_text)}")
                    continue
                class_id, mid_val = struct.unpack_from("!HH", payload, 0)
                method_payload = payload[4:]
                if (class_id, mid_val) == METHOD_CHANNEL_CLOSE:
                    reply_code = struct.unpack_from("!H", method_payload, 0)[0]
                    reply_text, _ = self._decode_short_string(method_payload, 2)
                    debug(f"Server closed channel: {reply_code} - {safe(reply_text)}")
                    self._send_method(channel, CLASS_CHANNEL, 41, b"")
                    raise AMQPError(f"Channel closed by server: {reply_code} - {safe(reply_text)}")
                if (class_id, mid_val) == METHOD_CONNECTION_CLOSE:
                    reply_code = struct.unpack_from("!H", method_payload, 0)[0]
                    reply_text, _ = self._decode_short_string(method_payload, 2)
                    debug(f"Server closed connection: {reply_code} - {safe(reply_text)}")
                    self._send_method(0, CLASS_CONNECTION, 51, b"")
                    raise AMQPError(f"Connection closed by server: {reply_code} - {safe(reply_text)}")
                return class_id, mid_val, method_payload

    def _send_frame(self, frame_type: int, channel: int, payload: bytes) -> None:
        frame = struct.pack("!BHI", frame_type, channel, len(payload))
        frame += payload
        frame += struct.pack("B", FRAME_END)
        self.sock.sendall(frame)

    def _send_method(self, channel: int, class_id: int, method_id_val: int, payload: bytes) -> None:
        method_payload = struct.pack("!HH", class_id, method_id_val) + payload
        debug(f"  >> Sending {method_name(class_id, method_id_val)} on ch={channel} ({len(payload)} bytes)")
        self._send_frame(FRAME_METHOD, channel, method_payload)

    def _send_connection_start_ok(self) -> None:
        client_props = self._encode_table({
            "product": "check_rabbitmq",
            "version": VERSION,
            "platform": "Python",
            "information": "Nagios/Icinga2 check plugin",
        })
        mechanism = self._encode_short_string("PLAIN")
        auth_response = b"\x00" + self.username.encode("utf-8") + b"\x00" + self.password.encode("utf-8")
        response = struct.pack("!I", len(auth_response)) + auth_response
        locale = self._encode_short_string("en_US")
        payload = client_props + mechanism + response + locale
        self._send_method(0, CLASS_CONNECTION, 11, payload)


# =============================================================================
# RabbitMQ Management API Client (HTTP, stdlib only)
# =============================================================================

class ManagementAPIClient:
    """Client for RabbitMQ Management HTTP API using only stdlib."""

    def __init__(self, host: str, port: int, username: str, password: str,
                 use_ssl: bool = False, ssl_ca_cert: Optional[str] = None,
                 ssl_no_verify: bool = False, timeout: int = 10):
        self.host = host
        self.port = port
        self.username = username
        self.password = password
        self.use_ssl = use_ssl
        self.ssl_ca_cert = ssl_ca_cert
        self.ssl_no_verify = ssl_no_verify
        self.timeout = timeout

    def _get_connection(self) -> http.client.HTTPConnection:
        scheme = "https" if self.use_ssl else "http"
        debug(f"HTTP: creating {scheme} connection to {self.host}:{self.port}")
        if self.use_ssl:
            ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_CLIENT)
            if self.ssl_no_verify:
                ctx.check_hostname = False
                ctx.verify_mode = ssl.CERT_NONE
                debug("HTTP TLS: certificate verification DISABLED")
            else:
                ctx.verify_mode = ssl.CERT_REQUIRED
                ctx.check_hostname = True
                if self.ssl_ca_cert:
                    ctx.load_verify_locations(self.ssl_ca_cert)
                    debug(f"HTTP TLS: loaded CA cert from {self.ssl_ca_cert}")
                else:
                    ctx.load_default_certs()
                    debug("HTTP TLS: using system default CA certificates")
            return http.client.HTTPSConnection(self.host, self.port, timeout=self.timeout, context=ctx)
        else:
            return http.client.HTTPConnection(self.host, self.port, timeout=self.timeout)

    def _auth_header(self) -> str:
        creds = base64.b64encode(f"{self.username}:{self.password}".encode()).decode()
        return f"Basic {creds}"

    def _request(self, method: str, path: str, body: Optional[str] = None) -> Tuple[int, Any]:
        conn = self._get_connection()
        headers = {"Authorization": self._auth_header(), "Content-Type": "application/json"}
        full_path = f"/api{path}"
        debug(f"HTTP {method} {full_path}")
        status = 0
        try:
            conn.request(method, full_path, body=body, headers=headers)
            resp = conn.getresponse()
            data = resp.read().decode("utf-8")
            status = resp.status
            debug(f"HTTP response: {status} ({len(data)} bytes)")
            if data and resp.getheader("Content-Type", "").startswith("application/json"):
                return status, json.loads(data)
            return status, data
        except json.JSONDecodeError as e:
            debug(f"HTTP response JSON parse error: {e}")
            return status, data
        finally:
            conn.close()

    def get(self, path: str) -> Tuple[int, Any]:
        return self._request("GET", path)

    def get_overview(self) -> Dict:
        debug("Fetching cluster overview via Management API")
        status, data = self.get("/overview")
        if status != 200:
            raise Exception(describe_http_error(status, "/overview", data))
        debug(f"Overview: cluster={data.get('cluster_name', '?')}, rmq={data.get('rabbitmq_version', '?')}")
        return data

    def get_nodes(self) -> List[Dict]:
        debug("Fetching node list via Management API")
        status, data = self.get("/nodes")
        if status != 200:
            raise Exception(describe_http_error(status, "/nodes", data))
        debug(f"Found {len(data)} node(s)")
        return data

    def get_health_checks(self) -> Dict:
        results = {}
        for endpoint in ["/health/checks/alarms", "/health/checks/local-alarms"]:
            try:
                debug(f"Checking health endpoint: {endpoint}")
                status, data = self.get(endpoint)
                results[endpoint] = {"status": status, "data": data}
                debug(f"Health check {endpoint}: {'OK' if status == 200 else f'HTTP {status}'}")
            except Exception as e:
                debug(f"Health check {endpoint}: error - {safe(str(e))}")
                results[endpoint] = {"status": -1, "error": str(e)}
        return results

    def get_queues(self, vhost: Optional[str] = None) -> List[Dict]:
        path = f"/queues/{urllib.parse.quote(vhost, safe='')}" if vhost else "/queues"
        debug(f"Listing queues: {path}")
        status, data = self.get(path)
        if status != 200:
            raise Exception(describe_http_error(status, path, data))
        debug(f"Found {len(data)} queue(s)")
        return data

    def get_exchanges(self, vhost: Optional[str] = None) -> List[Dict]:
        path = f"/exchanges/{urllib.parse.quote(vhost, safe='')}" if vhost else "/exchanges"
        debug(f"Listing exchanges: {path}")
        status, data = self.get(path)
        if status != 200:
            raise Exception(describe_http_error(status, path, data))
        debug(f"Found {len(data)} exchange(s)")
        return data

    def get_queue(self, vhost: str, queue_name: str) -> Optional[Dict]:
        path = f"/queues/{urllib.parse.quote(vhost, safe='')}/{urllib.parse.quote(queue_name, safe='')}"
        debug(f"Fetching queue details: {path}")
        status, data = self.get(path)
        if status == 404:
            debug(f"Queue '{queue_name}' not found (HTTP 404)")
            return None
        if status != 200:
            raise Exception(describe_http_error(status, path, data))
        debug(f"Queue '{queue_name}': state={data.get('state', '?')}, type={data.get('type', '?')}, "
              f"messages={data.get('messages', 0)}")
        return data

    def get_cluster_name(self) -> str:
        status, data = self.get("/cluster-name")
        if status != 200:
            return "unknown"
        return data.get("name", "unknown")


