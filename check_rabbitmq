# Duration parsing helper
# =============================================================================

def parse_duration(value: str) -> float:
    """
    Parse a human-friendly duration string into seconds.
    Supported formats: '30' (seconds), '30s', '5m', '1m30s', '90s'.
    Returns float seconds.
    """
    if not value:
        raise ValueError("Empty duration string")

    # Pure numeric = seconds
    try:
        return float(value)
    except ValueError:
        pass

    value = value.strip().lower()
    total = 0.0
    # Match patterns like 1m, 30s, 1m30s, 2m15s
    pattern = re.compile(r"(\d+(?:\.\d+)?)\s*([msh]?)")
    pos = 0
    found_any = False
    for match in pattern.finditer(value):
        if match.start() != pos:
            raise ValueError(f"Invalid duration format: '{value}'")
        num = float(match.group(1))
        unit = match.group(2)
        if unit == "m":
            total += num * 60
        elif unit == "h":
            total += num * 3600
        elif unit == "s" or unit == "":
            total += num
        else:
            raise ValueError(f"Unknown duration unit: '{unit}'")
        pos = match.end()
        found_any = True

    if not found_any or pos != len(value):
        raise ValueError(f"Invalid duration format: '{value}'")
    return total


