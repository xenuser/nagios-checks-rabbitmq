def _build_mgmt_client(args: argparse.Namespace) -> ManagementAPIClient:
    scheme = "https" if args.mgmt_ssl else "http"
    debug(f"Building Management API client: {scheme}://{args.host}:{args.mgmt_port} as user '{args.username}'")
    return ManagementAPIClient(
        host=args.host, port=args.mgmt_port, username=args.username, password=args.password,
        use_ssl=args.mgmt_ssl, ssl_ca_cert=args.ssl_ca_cert,
        ssl_no_verify=args.ssl_no_verify, timeout=args.timeout,
    )


# =============================================================================
# Argument Parsing
# =============================================================================

VERSION = "1.2.0"


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="check_rabbitmq",
        description=(
            "Nagios/Icinga2 compatible check plugin for RabbitMQ 4.x. "
            "No external dependencies - uses Python 3 stdlib only."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
MODES:
  publish_consume   Publish message(s), consume & verify (AMQP)
  queue_exists      Check if a specific queue exists (Management API)
  queue_count       Count queues, apply thresholds (Management API)
  exchange_count    Count exchanges, apply thresholds (Management API)
  cluster_health    Comprehensive cluster health check (Management API)

EXAMPLES:
  # Single-message roundtrip (default)
  %(prog)s -m publish_consume -H rabbit1 -u monitor -p secret

  # Publish 500 messages, consume all back, verify
  %(prog)s -m publish_consume -H rabbit1 -u monitor -p secret --message-count 500

  # Publish continuously for 30 seconds, then consume all back
  %(prog)s -m publish_consume -H rabbit1 -u monitor -p secret --publish-duration 30s

  # Publish for 2 minutes on a persistent named queue
  %(prog)s -m publish_consume -H rabbit1 -u monitor -p secret \\
           --publish-duration 2m --queue-name stress.test --no-delete

  # Re-use an existing queue (queue is never deleted)
  %(prog)s -m publish_consume -H rabbit1 -u monitor -p secret \\
           --queue-name my.health.check.queue

  # Keep temp queue after test (--no-delete)
  %(prog)s -m publish_consume -H rabbit1 -u monitor -p secret --no-delete

  # AMQPS (TLS)
  %(prog)s -m publish_consume -H rabbit1 -u monitor -p secret --amqps

  # Cluster health with debug output
  %(prog)s -m cluster_health -H rabbit1 -u monitor -p secret --debug

  # Queue/exchange counts with thresholds
  %(prog)s -m queue_count -H rabbit1 -u monitor -p secret -w 100 -c 500
  %(prog)s -m exchange_count -H rabbit1 -u monitor -p secret -w 50 -c 100

  # Check specific queue exists
  %(prog)s -m queue_exists -H rabbit1 -u monitor -p secret --queue-name orders.in

  # Management API over HTTPS
  %(prog)s -m cluster_health -H rabbit1 -u monitor -p secret \\
           --mgmt-port 15671 --mgmt-ssl --ssl-ca-cert /etc/pki/ca.pem

EXIT CODES:
  0  OK       - check passed
  1  WARNING  - threshold exceeded or non-critical issue
  2  CRITICAL - check failed, connection error, or critical threshold
  3  UNKNOWN  - invalid arguments or unhandled error
""",
    )

    parser.add_argument("-V", "--version", action="version", version=f"%(prog)s {VERSION}")

    parser.add_argument(
        "-m", "--mode", required=True,
        choices=["publish_consume", "queue_exists", "queue_count", "exchange_count", "cluster_health"],
        help="Check mode to execute",
    )

    conn = parser.add_argument_group("Connection options")
    conn.add_argument("-H", "--host", default="localhost", help="RabbitMQ hostname (default: localhost)")
    conn.add_argument("-u", "--username", default="guest", help="RabbitMQ username (default: guest)")
    conn.add_argument("-p", "--password", default="guest", help="RabbitMQ password (default: guest)")
    conn.add_argument("--vhost", default="/", help="AMQP vhost (default: /)")
    conn.add_argument("-t", "--timeout", type=int, default=10, help="Connection timeout in seconds (default: 10)")

    amqp = parser.add_argument_group("AMQP options (for publish_consume mode)")
    amqp.add_argument("--amqp-port", type=int, default=5672, help="AMQP port (default: 5672)")
    amqp.add_argument("--amqps", action="store_true", help="Use AMQPS (TLS)")

    mgmt = parser.add_argument_group("Management API options")
    mgmt.add_argument("--mgmt-port", type=int, default=15672, help="Management API port (default: 15672)")
    mgmt.add_argument("--mgmt-ssl", action="store_true", help="Use HTTPS for Management API")

    tls = parser.add_argument_group("TLS/SSL options")
    tls.add_argument("--ssl-ca-cert", help="CA certificate file for TLS verification")
    tls.add_argument("--ssl-cert", help="Client certificate file (AMQPS mutual TLS)")
    tls.add_argument("--ssl-key", help="Client private key file (AMQPS mutual TLS)")
    tls.add_argument("--ssl-no-verify", action="store_true", help="Disable TLS cert verification (insecure)")

    thresh = parser.add_argument_group("Thresholds")
    thresh.add_argument("-w", "--warning", type=float, default=None,
                        help="Warning threshold (ms for publish_consume, count for queue/exchange_count)")
    thresh.add_argument("-c", "--critical", type=float, default=None,
                        help="Critical threshold (ms for publish_consume, count for queue/exchange_count)")

    mode_opts = parser.add_argument_group("Mode-specific options")
    mode_opts.add_argument(
        "--queue-name",
        help="Queue name. For queue_exists: required. For publish_consume: re-use "
             "an existing queue instead of creating a temporary one.",
    )
    mode_opts.add_argument(
        "--no-delete", action="store_true",
        help="Do not delete the queue after publish_consume test",
    )
    mode_opts.add_argument("--filter-vhost",
                           help="Filter by vhost for queue_count/exchange_count")
    mode_opts.add_argument("--include-defaults", action="store_true",
                           help="Include default AMQP exchanges (amq.*) in exchange_count")

    vol = parser.add_argument_group("Publish volume (publish_consume mode, mutually exclusive)")
    vol_ex = vol.add_mutually_exclusive_group()
    vol_ex.add_argument(
        "--message-count", type=int, default=None,
        help="Number of messages to publish and consume (default: 1)",
    )
    vol_ex.add_argument(
        "--publish-duration", type=str, default=None,
        help="Publish messages continuously for this duration, then consume all. "
             "Formats: '30' (seconds), '30s', '5m', '1m30s'.",
    )

    parser.add_argument("--debug", "-d", action="store_true",
                        help="Enable debug output on stderr")

    return parser


# =============================================================================
# Main
# =============================================================================

def main() -> None:
    parser = build_parser()
    args = parser.parse_args()

    global _debug_enabled, _g_password, _g_username
    _debug_enabled = args.debug
    _g_password = args.password
    _g_username = args.username

    debug(f"check_rabbitmq v{VERSION} starting")
    debug(f"Mode: {args.mode}")
    debug(f"Host: {args.host}, AMQP port: {args.amqp_port}, Mgmt port: {args.mgmt_port}")
    debug(f"Vhost: {args.vhost}, User: {args.username}, Password: ***")
    debug(f"AMQPS: {args.amqps}, Mgmt SSL: {args.mgmt_ssl}, SSL no-verify: {args.ssl_no_verify}")
    debug(f"Timeout: {args.timeout}s, Warning: {args.warning}, Critical: {args.critical}")
    if args.mode == "publish_consume":
        debug(f"Queue name: {args.queue_name or '(auto-generated)'}, No-delete: {args.no_delete}")
        if args.message_count:
            debug(f"Message count: {args.message_count}")
        elif args.publish_duration:
            debug(f"Publish duration: {args.publish_duration}")
        else:
            debug("Message count: 1 (default)")

    if args.amqps and args.amqp_port == 5672:
        args.amqp_port = 5671
        debug(f"Auto-switched AMQP port to {args.amqp_port} for AMQPS")

    mode_map = {
        "publish_consume": check_publish_consume,
        "queue_exists": check_queue_exists,
        "queue_count": check_queue_count,
        "exchange_count": check_exchange_count,
        "cluster_health": check_cluster_health,
    }

    try:
        exit_code, message, perfdata = mode_map[args.mode](args)
    except Exception as e:
        exit_code = STATE_UNKNOWN
        message = f"UNKNOWN - Unhandled exception: {safe(str(e))}"
        perfdata = ""
        debug(f"Unhandled exception: {safe(traceback.format_exc())}")

    debug(f"Exit code: {exit_code} ({STATE_NAMES.get(exit_code, '?')})")

    if perfdata:
        print(f"{message} | {perfdata}")
    else:
        print(message)

    sys.exit(exit_code)


if __name__ == "__main__":
    main()
