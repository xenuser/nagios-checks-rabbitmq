            return (STATE_WARNING,
                    f"WARNING - {count} queues found in {vhost_label} (threshold: {args.warning})", perfdata)
        return (STATE_OK, f"OK - {count} queues in {vhost_label}", perfdata)
    except Exception as e:
        return (STATE_CRITICAL, f"CRITICAL - Failed to count queues: {safe(str(e))}", "")


