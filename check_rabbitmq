def check_publish_consume(args: argparse.Namespace) -> Tuple[int, str, str]:
    """
    Mode: publish_consume
    Publishes message(s) to a queue, consumes them back, verifies content.

    Volume control (mutually exclusive, default is 1 message):
      --message-count N     publish exactly N messages
      --publish-duration D  publish continuously for D seconds (e.g. '20s', '1m')

    Queue lifecycle:
      --queue-name NAME     re-use an existing queue (or create if absent)
      --no-delete           keep the queue after the test
    """
    # ---- determine queue name ----
    if args.queue_name:
        queue_name = args.queue_name
        queue_is_user_provided = True
        debug(f"Using user-specified queue name: '{queue_name}'")
    else:
        queue_name = f"icinga2_check_{uuid.uuid4().hex[:12]}"
        queue_is_user_provided = False
        debug(f"Generated temporary queue name: '{queue_name}'")

    should_delete = not args.no_delete
    if args.no_delete:
        debug("--no-delete is set: queue will NOT be deleted after the check")

    # ---- determine volume ----
    message_count = args.message_count  # int or None
    publish_duration = None             # float seconds or None
    if args.publish_duration:
        try:
            publish_duration = parse_duration(args.publish_duration)
        except ValueError as e:
            return (STATE_UNKNOWN, f"UNKNOWN - Invalid --publish-duration value: {e}", "")
        debug(f"Publish duration mode: will publish for {publish_duration:.1f}s")
    elif message_count is not None:
        if message_count < 1:
            return (STATE_UNKNOWN, "UNKNOWN - --message-count must be >= 1", "")
        debug(f"Message count mode: will publish {message_count} messages")
    else:
        message_count = 1
        debug("Default mode: 1 message")

    # ---- unique run ID to tag messages ----
    run_id = uuid.uuid4().hex[:16]

    client = None
    queue_was_created = False
    queue_existed_before = False

    try:
        t_start = time.monotonic()

        client = AMQPClient(
            host=args.host, port=args.amqp_port, vhost=args.vhost,
            username=args.username, password=args.password,
            use_ssl=args.amqps, ssl_ca_cert=args.ssl_ca_cert,
            ssl_cert=args.ssl_cert, ssl_key=args.ssl_key,
            ssl_no_verify=args.ssl_no_verify, timeout=args.timeout,
        )
        client.connect()
        t_connect = time.monotonic()

        client.open_channel()

        # ---- declare / reuse queue ----
        if queue_is_user_provided:
            try:
                debug(f"Checking if queue '{queue_name}' already exists (passive declare)")
                _name, _mc, _cc = client.declare_queue_passive(queue_name)
                debug(f"Queue '{queue_name}' exists: messages={_mc}, consumers={_cc}")
                queue_existed_before = True
            except AMQPError as e:
                err_str = str(e)
                if "NOT_FOUND" in err_str or "404" in err_str:
                    debug(f"Queue '{queue_name}' does not exist, creating as quorum queue")
                    client.open_channel()
                    client.declare_quorum_queue(queue_name)
                    queue_was_created = True
                else:
                    raise
        else:
            client.declare_quorum_queue(queue_name)
            queue_was_created = True

        t_declare = time.monotonic()

        # ---- publish phase ----
        published_tags: List[str] = []  # message identifiers for verification

        if publish_duration is not None:
            # Time-based publishing
            debug(f"Publishing messages for {publish_duration:.1f}s")
            deadline = time.monotonic() + publish_duration
            seq = 0
            while time.monotonic() < deadline:
                tag = f"{run_id}:{seq}"
                body = tag.encode("utf-8")
                client.basic_publish(exchange="", routing_key=queue_name, body=body)
                published_tags.append(tag)
                seq += 1
                if seq % 100 == 0:
                    elapsed = time.monotonic() - (deadline - publish_duration)
                    debug(f"  Published {seq} messages in {elapsed:.1f}s")
            debug(f"Publish phase complete: {len(published_tags)} messages in {publish_duration:.1f}s")
        else:
            # Count-based publishing
            debug(f"Publishing {message_count} message(s)")
            for seq in range(message_count):
                tag = f"{run_id}:{seq}"
                body = tag.encode("utf-8")
                client.basic_publish(exchange="", routing_key=queue_name, body=body)
                published_tags.append(tag)
                if (seq + 1) % 100 == 0:
                    debug(f"  Published {seq + 1}/{message_count} messages")
            debug(f"Publish phase complete: {len(published_tags)} messages")

        total_published = len(published_tags)
        t_publish = time.monotonic()

        # ---- consume phase ----
        # Brief pause for quorum replication before first get
        repl_wait = min(0.2 + total_published * 0.001, 2.0)  # scale with volume, cap at 2s
        debug(f"Waiting {repl_wait:.1f}s for quorum replication")
        time.sleep(repl_wait)

        expected_set = set(published_tags)
        received_set: set = set()
        consume_errors = 0
        max_consume_attempts = total_published + 10  # safety bound to avoid infinite loops
        attempts = 0

        debug(f"Consuming: expecting {total_published} messages")

        while len(received_set) < total_published and attempts < max_consume_attempts:
            result = client.basic_get(queue_name)
            attempts += 1

            if result is None:
                # Queue empty but we haven't got all messages yet.
                # Retry a few times with brief pauses.
                if attempts < max_consume_attempts:
                    time.sleep(0.1)
                    continue
                else:
                    break

            delivery_tag_val, body = result
            client.basic_ack(delivery_tag_val)
            received_tag = body.decode("utf-8")

            if received_tag in expected_set:
                received_set.add(received_tag)
            else:
                # Message from a previous run or unknown origin - not an error
                # when reusing an existing queue. Just skip it.
                debug(f"  Skipped foreign message (not from this run): {received_tag[:40]}")

            if len(received_set) % 100 == 0 and len(received_set) > 0:
                debug(f"  Consumed {len(received_set)}/{total_published} messages")

        t_consume = time.monotonic()

        total_received = len(received_set)
        missing = total_published - total_received
        debug(f"Consume phase complete: received={total_received}/{total_published}, "
              f"attempts={attempts}, missing={missing}")

        if missing > 0:
            debug(f"FAILED: {missing} message(s) not consumed back")
            _cleanup_queue(client, queue_name, should_delete, queue_was_created, queue_existed_before)
            client.close()

            perfdata = (
                f"published={total_published};;;; "
                f"consumed={total_received};;;; "
                f"missing={missing};;;;"
            )
            return (
                STATE_CRITICAL,
                f"CRITICAL - Published {total_published} but only consumed {total_received} "
                f"({missing} missing, queue: {queue_name})",
                perfdata,
            )

        debug(f"All {total_published} messages verified successfully")

        # ---- cleanup ----
        _cleanup_queue(client, queue_name, should_delete, queue_was_created, queue_existed_before)

        client.close()
        t_total = time.monotonic()

        # ---- timings & perfdata ----
        connect_ms = (t_connect - t_start) * 1000
        declare_ms = (t_declare - t_connect) * 1000
        publish_ms = (t_publish - t_declare) * 1000
        consume_ms = (t_consume - t_publish) * 1000
        total_ms = (t_total - t_start) * 1000

        # Rates
        publish_elapsed = (t_publish - t_declare)
        consume_elapsed = (t_consume - t_publish)
        publish_rate = total_published / publish_elapsed if publish_elapsed > 0 else 0
        consume_rate = total_received / consume_elapsed if consume_elapsed > 0 else 0

        debug(f"Timings: connect={connect_ms:.1f}ms, declare={declare_ms:.1f}ms, "
              f"publish={publish_ms:.1f}ms, consume={consume_ms:.1f}ms, total={total_ms:.1f}ms")
        debug(f"Rates: publish={publish_rate:.1f} msg/s, consume={consume_rate:.1f} msg/s")

        perfdata = (
            f"connect_time={connect_ms:.1f}ms;;;; "
            f"declare_time={declare_ms:.1f}ms;;;; "
            f"publish_time={publish_ms:.1f}ms;;;; "
            f"consume_time={consume_ms:.1f}ms;;;; "
            f"total_time={total_ms:.1f}ms;;;; "
            f"published={total_published};;;; "
            f"consumed={total_received};;;; "
            f"publish_rate={publish_rate:.1f};;;; "
            f"consume_rate={consume_rate:.1f};;;;"
        )

        # ---- thresholds on total_time ----
        if args.critical and total_ms > args.critical:
            return (
                STATE_CRITICAL,
                f"CRITICAL - Publish/consume roundtrip took {total_ms:.1f}ms "
                f"({total_published} msgs, threshold: {args.critical}ms)",
                perfdata,
            )
        if args.warning and total_ms > args.warning:
            return (
                STATE_WARNING,
                f"WARNING - Publish/consume roundtrip took {total_ms:.1f}ms "
                f"({total_published} msgs, threshold: {args.warning}ms)",
                perfdata,
            )

        # ---- success ----
        proto = "amqps" if args.amqps else "amqp"
        queue_info = f"queue: {queue_name}"
        if queue_existed_before:
            queue_info += ", reused"
        elif queue_was_created:
            queue_info += ", created"
        if not should_delete or queue_existed_before:
            queue_info += ", kept"
        else:
            queue_info += ", deleted"

        if total_published == 1:
            summary = f"roundtrip in {total_ms:.1f}ms"
        else:
            summary = (
                f"{total_published} msgs in {total_ms:.1f}ms "
                f"(pub: {publish_rate:.0f} msg/s, con: {consume_rate:.0f} msg/s)"
            )

        return (
            STATE_OK,
            f"OK - Publish/consume {summary} via {proto} ({queue_info}, vhost: {args.vhost})",
            perfdata,
        )

    except Exception as e:
        if client:
            try:
                if should_delete and queue_was_created and not queue_existed_before:
                    debug(f"Error path: attempting to clean up queue '{queue_name}'")
                    client.delete_queue(queue_name)
            except Exception as cleanup_err:
                debug(f"Error path: cleanup failed: {safe(str(cleanup_err))}")
            client.close()
        return (STATE_CRITICAL, f"CRITICAL - Publish/consume test failed: {safe(str(e))}", "")


def _cleanup_queue(client: AMQPClient, queue_name: str, should_delete: bool,
                   queue_was_created: bool, queue_existed_before: bool) -> None:
    """
    Decide whether to delete the queue.
    Rules:
    - If --no-delete: never delete
    - If queue existed before (not ours): never delete
    - If we created it: delete
    """
    if not should_delete:
        debug(f"Keeping queue '{queue_name}' (--no-delete)")
        return
    if queue_existed_before:
        debug(f"Keeping queue '{queue_name}' (existed before this check, not ours to delete)")
        return
    if queue_was_created:
        debug(f"Deleting queue '{queue_name}' (created by this check)")
        client.delete_queue(queue_name)
    else:
        debug(f"Keeping queue '{queue_name}' (was not created by this check)")


def check_queue_exists(args: argparse.Namespace) -> Tuple[int, str, str]:
    """Check if a specific queue exists and report its state."""
    if not args.queue_name:
        return (STATE_UNKNOWN, "UNKNOWN - --queue-name is required for queue_exists mode", "")
    debug(f"Checking if queue '{args.queue_name}' exists in vhost '{args.vhost}'")
    try:
        mgmt = _build_mgmt_client(args)
        queue = mgmt.get_queue(args.vhost, args.queue_name)
        if queue is None:
            debug(f"Queue '{args.queue_name}' does not exist")
            return (STATE_CRITICAL,
                    f"CRITICAL - Queue '{args.queue_name}' does not exist in vhost '{args.vhost}'", "")
        msg_count = queue.get("messages", 0)
        consumers = queue.get("consumers", 0)
        q_type = queue.get("type", "unknown")
        state = queue.get("state", "unknown")
        debug(f"Queue found: type={q_type}, state={state}, messages={msg_count}, consumers={consumers}")
        perfdata = (f"messages={msg_count};;;; consumers={consumers};;;; "
                    f"messages_ready={queue.get('messages_ready', 0)};;;; "
                    f"messages_unacked={queue.get('messages_unacknowledged', 0)};;;;")
        if state != "running":
            return (STATE_WARNING,
                    f"WARNING - Queue '{args.queue_name}' exists but state is '{state}' "
                    f"(type={q_type}, messages={msg_count}, consumers={consumers})", perfdata)
        return (STATE_OK,
                f"OK - Queue '{args.queue_name}' exists and is running "
                f"(type={q_type}, messages={msg_count}, consumers={consumers})", perfdata)
    except Exception as e:
        return (STATE_CRITICAL, f"CRITICAL - Failed to check queue: {safe(str(e))}", "")


def check_queue_count(args: argparse.Namespace) -> Tuple[int, str, str]:
