class ManagementAPIClient:
    """Client for RabbitMQ Management HTTP API using only stdlib."""

    def __init__(
        self,
        host: str,
        port: int,
        username: str,
        password: str,
        use_ssl: bool = False,
        ssl_ca_cert: Optional[str] = None,
        ssl_no_verify: bool = False,
        timeout: int = 10,
    ):
        self.host = host
        self.port = port
        self.username = username
        self.password = password
        self.use_ssl = use_ssl
        self.ssl_ca_cert = ssl_ca_cert
        self.ssl_no_verify = ssl_no_verify
        self.timeout = timeout

    def _get_connection(self) -> http.client.HTTPConnection:
        if self.use_ssl:
            ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_CLIENT)
            if self.ssl_no_verify:
                ctx.check_hostname = False
                ctx.verify_mode = ssl.CERT_NONE
            else:
                ctx.verify_mode = ssl.CERT_REQUIRED
                ctx.check_hostname = True
                if self.ssl_ca_cert:
                    ctx.load_verify_locations(self.ssl_ca_cert)
                else:
                    ctx.load_default_certs()
            return http.client.HTTPSConnection(
                self.host, self.port, timeout=self.timeout, context=ctx
            )
        else:
            return http.client.HTTPConnection(
                self.host, self.port, timeout=self.timeout
            )

    def _auth_header(self) -> str:
        creds = base64.b64encode(
            f"{self.username}:{self.password}".encode()
        ).decode()
        return f"Basic {creds}"

    def _request(self, method: str, path: str, body: Optional[str] = None) -> Tuple[int, Any]:
        conn = self._get_connection()
        headers = {
            "Authorization": self._auth_header(),
            "Content-Type": "application/json",
        }
        try:
            conn.request(method, f"/api{path}", body=body, headers=headers)
            resp = conn.getresponse()
            data = resp.read().decode("utf-8")
            status = resp.status
            if data and resp.getheader("Content-Type", "").startswith("application/json"):
                return status, json.loads(data)
            return status, data
        finally:
            conn.close()

    def get(self, path: str) -> Tuple[int, Any]:
        return self._request("GET", path)

    def get_overview(self) -> Dict:
        status, data = self.get("/overview")
        if status != 200:
            raise Exception(f"Management API /overview returned HTTP {status}")
        return data

    def get_nodes(self) -> List[Dict]:
        status, data = self.get("/nodes")
        if status != 200:
            raise Exception(f"Management API /nodes returned HTTP {status}")
        return data

    def get_health_checks(self) -> Dict:
        """Aggregate multiple health check endpoints."""
        results = {}
        for endpoint in [
            "/health/checks/alarms",
            "/health/checks/local-alarms",
        ]:
            try:
                status, data = self.get(endpoint)
                results[endpoint] = {"status": status, "data": data}
            except Exception as e:
                results[endpoint] = {"status": -1, "error": str(e)}
        return results

    def get_queues(self, vhost: Optional[str] = None) -> List[Dict]:
        if vhost:
            path = f"/queues/{urllib.parse.quote(vhost, safe='')}"
        else:
            path = "/queues"
        status, data = self.get(path)
        if status != 200:
            raise Exception(f"Management API {path} returned HTTP {status}")
        return data

    def get_exchanges(self, vhost: Optional[str] = None) -> List[Dict]:
        if vhost:
            path = f"/exchanges/{urllib.parse.quote(vhost, safe='')}"
        else:
            path = "/exchanges"
        status, data = self.get(path)
        if status != 200:
            raise Exception(f"Management API {path} returned HTTP {status}")
        return data

    def get_queue(self, vhost: str, queue_name: str) -> Optional[Dict]:
        path = f"/queues/{urllib.parse.quote(vhost, safe='')}/{urllib.parse.quote(queue_name, safe='')}"
        status, data = self.get(path)
        if status == 404:
            return None
        if status != 200:
            raise Exception(f"Management API {path} returned HTTP {status}")
        return data

    def get_cluster_name(self) -> str:
        status, data = self.get("/cluster-name")
        if status != 200:
            return "unknown"
        return data.get("name", "unknown")


