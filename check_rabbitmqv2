def check_publish_consume(args: argparse.Namespace) -> Tuple[int, str, str]:
    """
    Mode: publish_consume
    Creates a quorum queue, publishes a message, consumes it back, verifies, cleans up.
    """
    queue_name = f"icinga2_check_{uuid.uuid4().hex[:12]}"
    test_message = f"check_rabbitmq_test_{uuid.uuid4().hex}"
    client = None
    perfdata_parts = []

    try:
        t_start = time.monotonic()

        client = AMQPClient(
            host=args.host,
            port=args.amqp_port,
            vhost=args.vhost,
            username=args.username,
            password=args.password,
            use_ssl=args.amqps,
            ssl_ca_cert=args.ssl_ca_cert,
            ssl_cert=args.ssl_cert,
            ssl_key=args.ssl_key,
            ssl_no_verify=args.ssl_no_verify,
            timeout=args.timeout,
        )
        client.connect()
        t_connect = time.monotonic()

        client.open_channel()

        # Declare quorum queue
        declared_name, _, _ = client.declare_quorum_queue(queue_name)
        t_declare = time.monotonic()

        # Publish
        client.basic_publish(
            exchange="",
            routing_key=queue_name,
            body=test_message.encode("utf-8"),
        )
        t_publish = time.monotonic()

        # Brief pause for quorum replication
        time.sleep(0.2)

        # Consume
        result = client.basic_get(queue_name)
        t_consume = time.monotonic()

        if result is None:
            # Retry once after a short delay
            time.sleep(0.5)
            result = client.basic_get(queue_name)
            t_consume = time.monotonic()

        if result is None:
            client.delete_queue(queue_name)
            client.close()
            return (
                STATE_CRITICAL,
                "CRITICAL - Published message but could not consume it back",
                "",
            )

        delivery_tag, body = result
        client.basic_ack(delivery_tag)

        # Verify message content
        received = body.decode("utf-8")
        if received != test_message:
            client.delete_queue(queue_name)
            client.close()
            return (
                STATE_CRITICAL,
                f"CRITICAL - Message content mismatch: expected '{test_message}', got '{received}'",
                "",
            )

        # Cleanup
        client.delete_queue(queue_name)
        t_cleanup = time.monotonic()

        client.close()
        t_total = time.monotonic()

        # Calculate timings
        connect_ms = (t_connect - t_start) * 1000
        declare_ms = (t_declare - t_connect) * 1000
        publish_ms = (t_publish - t_declare) * 1000
        consume_ms = (t_consume - t_publish) * 1000
        total_ms = (t_total - t_start) * 1000

        perfdata = (
            f"connect_time={connect_ms:.1f}ms;;;; "
            f"declare_time={declare_ms:.1f}ms;;;; "
            f"publish_time={publish_ms:.1f}ms;;;; "
            f"consume_time={consume_ms:.1f}ms;;;; "
            f"total_time={total_ms:.1f}ms"
        )

        # Apply thresholds on total_time
        if args.critical and total_ms > args.critical:
            return (
                STATE_CRITICAL,
                f"CRITICAL - Publish/consume roundtrip took {total_ms:.1f}ms (threshold: {args.critical}ms)",
                perfdata,
            )
        if args.warning and total_ms > args.warning:
            return (
                STATE_WARNING,
                f"WARNING - Publish/consume roundtrip took {total_ms:.1f}ms (threshold: {args.warning}ms)",
                perfdata,
            )

        proto = "amqps" if args.amqps else "amqp"
        return (
            STATE_OK,
            f"OK - Publish/consume roundtrip successful via {proto} in {total_ms:.1f}ms "
            f"(queue: quorum, vhost: {args.vhost})",
            perfdata,
        )

    except Exception as e:
        if client:
            try:
                # Try to clean up the queue
                client.delete_queue(queue_name)
            except Exception:
                pass
            client.close()
        return (STATE_CRITICAL, f"CRITICAL - Publish/consume test failed: {e}", "")


def check_queue_exists(args: argparse.Namespace) -> Tuple[int, str, str]:
    """
    Mode: queue_exists
    Check if a specific queue exists and report its state.
    """
    if not args.queue_name:
        return (STATE_UNKNOWN, "UNKNOWN - --queue-name is required for queue_exists mode", "")

    try:
        mgmt = _build_mgmt_client(args)
        queue = mgmt.get_queue(args.vhost, args.queue_name)

        if queue is None:
            return (
                STATE_CRITICAL,
                f"CRITICAL - Queue '{args.queue_name}' does not exist in vhost '{args.vhost}'",
                "",
            )

        msg_count = queue.get("messages", 0)
        consumers = queue.get("consumers", 0)
        q_type = queue.get("type", "unknown")
        state = queue.get("state", "unknown")

        perfdata = (
            f"messages={msg_count};;;; "
            f"consumers={consumers};;;; "
            f"messages_ready={queue.get('messages_ready', 0)};;;; "
            f"messages_unacked={queue.get('messages_unacknowledged', 0)};;;;"
        )

        if state != "running":
            return (
                STATE_WARNING,
                f"WARNING - Queue '{args.queue_name}' exists but state is '{state}' "
                f"(type={q_type}, messages={msg_count}, consumers={consumers})",
                perfdata,
            )

        return (
            STATE_OK,
            f"OK - Queue '{args.queue_name}' exists and is running "
            f"(type={q_type}, messages={msg_count}, consumers={consumers})",
            perfdata,
        )

    except Exception as e:
        return (STATE_CRITICAL, f"CRITICAL - Failed to check queue: {e}", "")


def check_queue_count(args: argparse.Namespace) -> Tuple[int, str, str]:
    """
    Mode: queue_count
    Count the number of queues, optionally filtered by vhost.
    """
    try:
        mgmt = _build_mgmt_client(args)
        vhost = args.vhost if args.vhost != "/" or args.filter_vhost else None
        if args.filter_vhost:
            vhost = args.filter_vhost

        queues = mgmt.get_queues(vhost)
        count = len(queues)

        perfdata = f"queue_count={count};"
        if args.warning is not None:
            perfdata += f"{args.warning}"
        perfdata += ";"
        if args.critical is not None:
            perfdata += f"{args.critical}"
        perfdata += ";0;"

        vhost_label = vhost if vhost else "all vhosts"

        if args.critical is not None and count >= args.critical:
            return (
                STATE_CRITICAL,
                f"CRITICAL - {count} queues found in {vhost_label} (threshold: {args.critical})",
                perfdata,
            )
        if args.warning is not None and count >= args.warning:
            return (
                STATE_WARNING,
                f"WARNING - {count} queues found in {vhost_label} (threshold: {args.warning})",
                perfdata,
            )

        return (STATE_OK, f"OK - {count} queues in {vhost_label}", perfdata)

    except Exception as e:
        return (STATE_CRITICAL, f"CRITICAL - Failed to count queues: {e}", "")


def check_exchange_count(args: argparse.Namespace) -> Tuple[int, str, str]:
    """
    Mode: exchange_count
    Count the number of exchanges, optionally filtered by vhost.
    """
    try:
        mgmt = _build_mgmt_client(args)
