def check_cluster_health(args: argparse.Namespace) -> Tuple[int, str, str]:
    """
    Mode: cluster_health
    Comprehensive cluster health check via Management API.
    """
    problems = []
    warnings = []
    info_parts = []
    perfdata_parts = []

    try:
        mgmt = _build_mgmt_client(args)

        # ---- Overview ----
        overview = mgmt.get_overview()
        cluster_name = overview.get("cluster_name", "unknown")
        rmq_version = overview.get("rabbitmq_version", "unknown")
        erlang_version = overview.get("erlang_version", "unknown")
        info_parts.append(f"cluster={cluster_name}")
        info_parts.append(f"rabbitmq={rmq_version}")
        info_parts.append(f"erlang={erlang_version}")

        # Listeners
        listeners = overview.get("listeners", [])
        listener_protos = set()
        for l in listeners:
            listener_protos.add(l.get("protocol", "unknown"))

        # Object totals
        obj_totals = overview.get("object_totals", {})
        total_queues = obj_totals.get("queues", 0)
        total_exchanges = obj_totals.get("exchanges", 0)
        total_connections = obj_totals.get("connections", 0)
        total_channels = obj_totals.get("channels", 0)
        total_consumers = obj_totals.get("consumers", 0)

        perfdata_parts.append(f"queues={total_queues};;;;")
        perfdata_parts.append(f"exchanges={total_exchanges};;;;")
        perfdata_parts.append(f"connections={total_connections};;;;")
        perfdata_parts.append(f"channels={total_channels};;;;")
        perfdata_parts.append(f"consumers={total_consumers};;;;")

        # Message stats from overview
        queue_totals = overview.get("queue_totals", {})
        total_messages = queue_totals.get("messages", 0)
        messages_ready = queue_totals.get("messages_ready", 0)
        messages_unacked = queue_totals.get("messages_unacknowledged", 0)
        perfdata_parts.append(f"messages={total_messages};;;;")
        perfdata_parts.append(f"messages_ready={messages_ready};;;;")
        perfdata_parts.append(f"messages_unacked={messages_unacked};;;;")

        # ---- Nodes ----
        nodes = mgmt.get_nodes()
        total_nodes = len(nodes)
        running_nodes = 0
        maintenance_nodes = 0
        disk_alarm_nodes = 0
        mem_alarm_nodes = 0
        node_names = []

        for node in nodes:
            name = node.get("name", "unknown")
            node_names.append(name)
            is_running = node.get("running", False)
            if is_running:
                running_nodes += 1

            # Check maintenance mode (drain status)
            if node.get("maintenance_status", "") == "draining" or node.get("being_drained", False):
                maintenance_nodes += 1

            # Memory alarm
            if node.get("mem_alarm", False):
                mem_alarm_nodes += 1
                problems.append(f"Memory alarm on {name}")

            # Disk alarm
            if node.get("disk_free_alarm", False):
                disk_alarm_nodes += 1
                problems.append(f"Disk free alarm on {name}")

            # File descriptors
            fd_used = node.get("fd_used", 0)
            fd_total = node.get("fd_total", 1)
            if fd_total > 0 and fd_used / fd_total > 0.9:
                warnings.append(f"FD usage high on {name}: {fd_used}/{fd_total}")

            # Socket descriptors
            sock_used = node.get("sockets_used", 0)
            sock_total = node.get("sockets_total", 1)
            if sock_total > 0 and sock_used / sock_total > 0.9:
                warnings.append(f"Socket usage high on {name}: {sock_used}/{sock_total}")

            # Memory usage
            mem_used = node.get("mem_used", 0)
            mem_limit = node.get("mem_limit", 0)
            if mem_limit > 0:
                mem_pct = (mem_used / mem_limit) * 100
                if mem_pct > 90:
                    warnings.append(f"Memory usage high on {name}: {mem_pct:.1f}%")

            # Disk free
            disk_free = node.get("disk_free", 0)
            disk_free_limit = node.get("disk_free_limit", 0)
            if disk_free_limit > 0 and disk_free > 0:
                disk_ratio = disk_free / disk_free_limit
                if disk_ratio < 1.5:
                    warnings.append(
                        f"Disk free low on {name}: {disk_free // (1024*1024)}MB "
                        f"(limit: {disk_free_limit // (1024*1024)}MB)"
                    )

            # Per-node perfdata
            short_name = name.split("@")[-1] if "@" in name else name
            short_name = short_name.replace(".", "_")
            if mem_limit > 0:
                perfdata_parts.append(
                    f"{short_name}_mem_pct={(mem_used / mem_limit * 100):.1f}%;90;95;0;100"
                )
            perfdata_parts.append(f"{short_name}_fd_used={fd_used};;;;{fd_total}")
            perfdata_parts.append(f"{short_name}_sockets_used={sock_used};;;;{sock_total}")

        perfdata_parts.insert(0, f"nodes_running={running_nodes};;;;{total_nodes}")
        perfdata_parts.insert(1, f"nodes_total={total_nodes};;;;")

        if not nodes:
            problems.append("No nodes reported by management API")

        if running_nodes < total_nodes:
            down_count = total_nodes - running_nodes
            problems.append(f"{down_count}/{total_nodes} nodes not running")

        if maintenance_nodes > 0:
            warnings.append(f"{maintenance_nodes} node(s) in maintenance/draining mode")

        info_parts.append(f"nodes={running_nodes}/{total_nodes} running")
        info_parts.append(f"protocols={','.join(sorted(listener_protos))}")

        if maintenance_nodes > 0:
            info_parts.append(f"maintenance={maintenance_nodes}")

        # ---- Health checks ----
        health = mgmt.get_health_checks()
        for endpoint, result in health.items():
            if result.get("status") == 200:
                # Check response body for alarm details
                data = result.get("data", {})
                if isinstance(data, dict) and data.get("status") == "ok":
                    continue
                elif isinstance(data, dict) and data.get("status") == "failed":
                    reason = data.get("reason", "unknown")
                    problems.append(f"Health check {endpoint} failed: {reason}")
            elif result.get("status", 0) > 0:
                problems.append(
                    f"Health check {endpoint} returned HTTP {result['status']}"
                )
            else:
                warnings.append(
                    f"Health check {endpoint} error: {result.get('error', 'unknown')}"
                )

        # ---- Build output ----
        perfdata = " ".join(perfdata_parts)
        info_str = ", ".join(info_parts)

        if problems:
            detail = "; ".join(problems)
            if warnings:
                detail += " | Warnings: " + "; ".join(warnings)
            return (
                STATE_CRITICAL,
                f"CRITICAL - {detail} [{info_str}]",
                perfdata,
            )
        elif warnings:
            detail = "; ".join(warnings)
            return (
                STATE_WARNING,
                f"WARNING - {detail} [{info_str}]",
                perfdata,
            )
        else:
            return (
                STATE_OK,
                f"OK - Cluster healthy [{info_str}]",
                perfdata,
            )

    except Exception as e:
        return (STATE_CRITICAL, f"CRITICAL - Cluster health check failed: {e}", "")


# =============================================================================
# Helpers
# =============================================================================

def _build_mgmt_client(args: argparse.Namespace) -> ManagementAPIClient:
    return ManagementAPIClient(
        host=args.host,
        port=args.mgmt_port,
        username=args.username,
        password=args.password,
        use_ssl=args.mgmt_ssl,
        ssl_ca_cert=args.ssl_ca_cert,
        ssl_no_verify=args.ssl_no_verify,
        timeout=args.timeout,
    )


# =============================================================================
# Argument Parsing
# =============================================================================

VERSION = "1.0.0"


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="check_rabbitmq",
        description=(
            "Nagios/Icinga2 compatible check plugin for RabbitMQ 4.x. "
            "No external dependencies - uses Python 3 stdlib only."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
MODES:
  publish_consume   Create quorum queue, publish message, consume & verify (AMQP)
  queue_exists      Check if a specific queue exists (Management API)
  queue_count       Count queues, apply thresholds (Management API)
  exchange_count    Count exchanges, apply thresholds (Management API)
  cluster_health    Comprehensive cluster health check (Management API)

EXAMPLES:
  # Publish/consume roundtrip test via AMQP
  %(prog)s -m publish_consume -H rabbit1.example.com -u monitor -p secret

  # Same but using AMQPS (TLS)
  %(prog)s -m publish_consume -H rabbit1.example.com -u monitor -p secret --amqps

  # Check if a specific queue exists
  %(prog)s -m queue_exists -H rabbit1.example.com -u monitor -p secret --queue-name my.app.queue

  # Count queues with warning/critical thresholds
  %(prog)s -m queue_count -H rabbit1.example.com -u monitor -p secret -w 100 -c 200

  # Full cluster health check
  %(prog)s -m cluster_health -H rabbit1.example.com -u monitor -p secret

  # Use a non-default vhost
  %(prog)s -m publish_consume -H rabbit1.example.com -u monitor -p secret --vhost /production

  # Custom ports and TLS for management API
  %(prog)s -m cluster_health -H rabbit1.example.com -u monitor -p secret \\
           --mgmt-port 15671 --mgmt-ssl --ssl-ca-cert /etc/pki/ca.pem

EXIT CODES:
  0  OK
  1  WARNING
  2  CRITICAL
  3  UNKNOWN
""",
    )

    parser.add_argument("-V", "--version", action="version", version=f"%(prog)s {VERSION}")

    # Mode
    parser.add_argument(
        "-m", "--mode",
        required=True,
        choices=["publish_consume", "queue_exists", "queue_count", "exchange_count", "cluster_health"],
        help="Check mode to execute",
    )

    # Connection
    conn = parser.add_argument_group("Connection options")
    conn.add_argument("-H", "--host", default="localhost", help="RabbitMQ hostname (default: localhost)")
    conn.add_argument("-u", "--username", default="guest", help="RabbitMQ username (default: guest)")
    conn.add_argument("-p", "--password", default="guest", help="RabbitMQ password (default: guest)")
    conn.add_argument("--vhost", default="/", help="AMQP vhost (default: /)")
    conn.add_argument("-t", "--timeout", type=int, default=10, help="Connection timeout in seconds (default: 10)")

    # AMQP
    amqp = parser.add_argument_group("AMQP options (for publish_consume mode)")
    amqp.add_argument("--amqp-port", type=int, default=5672, help="AMQP port (default: 5672)")
    amqp.add_argument("--amqps", action="store_true", help="Use AMQPS (TLS) for AMQP connection")

    # Management API
    mgmt = parser.add_argument_group("Management API options (for queue/exchange/health modes)")
    mgmt.add_argument("--mgmt-port", type=int, default=15672, help="Management API port (default: 15672)")
    mgmt.add_argument("--mgmt-ssl", action="store_true", help="Use HTTPS for Management API")

    # TLS
    tls = parser.add_argument_group("TLS/SSL options")
    tls.add_argument("--ssl-ca-cert", help="Path to CA certificate file for TLS verification")
    tls.add_argument("--ssl-cert", help="Path to client certificate file (for AMQPS mutual TLS)")
    tls.add_argument("--ssl-key", help="Path to client private key file (for AMQPS mutual TLS)")
    tls.add_argument("--ssl-no-verify", action="store_true", help="Disable TLS certificate verification (insecure)")

    # Thresholds
    thresh = parser.add_argument_group("Thresholds")
    thresh.add_argument(
        "-w", "--warning", type=float, default=None,
        help="Warning threshold (ms for publish_consume, count for queue/exchange_count)",
    )
    thresh.add_argument(
        "-c", "--critical", type=float, default=None,
        help="Critical threshold (ms for publish_consume, count for queue/exchange_count)",
    )

    # Mode-specific
    mode_opts = parser.add_argument_group("Mode-specific options")
    mode_opts.add_argument("--queue-name", help="Queue name (required for queue_exists mode)")
    mode_opts.add_argument(
        "--filter-vhost",
        help="Filter by vhost for queue_count/exchange_count (overrides --vhost for filtering)",
    )
    mode_opts.add_argument(
        "--include-defaults",
        action="store_true",
        help="Include default AMQP exchanges (amq.*) in exchange_count",
    )

    return parser


# =============================================================================
# Main
# =============================================================================

def main() -> None:
    parser = build_parser()
    args = parser.parse_args()

    # Override AMQP port if using AMQPS and port was not explicitly set
    if args.amqps and args.amqp_port == 5672:
        args.amqp_port = 5671

    mode_map = {
        "publish_consume": check_publish_consume,
        "queue_exists": check_queue_exists,
        "queue_count": check_queue_count,
        "exchange_count": check_exchange_count,
        "cluster_health": check_cluster_health,
    }

    try:
        exit_code, message, perfdata = mode_map[args.mode](args)
    except Exception as e:
        exit_code = STATE_UNKNOWN
        message = f"UNKNOWN - Unhandled exception: {e}"
        perfdata = ""

    # Nagios-compatible output format: TEXT | perfdata
    if perfdata:
        print(f"{message} | {perfdata}")
    else:
        print(message)

    sys.exit(exit_code)


if __name__ == "__main__":
    main()
